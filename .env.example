# --- Groq (vision OCR for bill screenshots) ---
GROQ_API_KEY=gsk_your_key_here
OCR_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- Browser path (src/run.ts) — needs a logged-in Chrome on CDP ---
# Start Chrome on the VPS with: --remote-debugging-port=9222  (see README)
BROWSER_CDP_URL=http://localhost:9222

# --- Browserless path (src/run-api.ts) — X GraphQL, NO Chrome needed ---
# Two cookies from a logged-in (burner) X account. Get them in a browser:
#   DevTools → Application → Cookies → https://x.com → copy the values.
# They last a few weeks; refresh when search starts returning 401/403.
X_AUTH_TOKEN=
X_CT0=
# Campaign tags to search (comma-separated). Latest tab, all post types.
X_QUERIES=#krexabillchallenge

# --- Campaign ---
CAMPAIGN=krexa
# comma-separated search terms. Latest-tab search, all post types count.
QUERIES=#KrexaBillChallenge,@krexa_xyz,#Krexa
# turn OCR on/off (off = collect posts only, no bill reading)
OCR=true

# --- Harvest limits ---
MAX_POSTS=10000
MAX_IDLE_ROUNDS=25

# --- Service ---
# minutes between scrape cycles in --watch mode
INTERVAL_MIN=30
# HTTP port that serves leaderboard.json / mentions.csv / healthz
PORT=8080
# where master.json + CSVs are written (local cache / audit trail)
DATA_DIR=data
LOG_LEVEL=info

# --- Database (the site reads from here) ---
# Postgres connection string. Render Postgres / Supabase / Neon / any Postgres.
# Example: postgresql://user:pass@host:5432/dbname
DATABASE_URL=
# SSL: leave default (on) for hosted DBs; set to false only for a local Postgres.
DATABASE_SSL=true

# --- Optional extra: also POST the leaderboard JSON to a webhook ---
WEBHOOK_URL=
WEBHOOK_SECRET=
